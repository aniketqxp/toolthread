# ---------------------------------------------------------------------------
# Toolthread secrets / env. Copy to .env (gitignored) and fill in.
# On Lightning AI / Kaggle, prefer the platform secret manager over a committed
# file (Kaggle Secrets, Lightning environment variables).
# ---------------------------------------------------------------------------

# Hugging Face — pull model weights, and (later) push adapters/checkpoints.
# Read automatically by huggingface_hub / transformers.
HF_TOKEN=

# Weights & Biases — eval/run logging. Read automatically by wandb.
WANDB_API_KEY=

# BFCL requires an explicit project root when pip-installed. All generated
# responses and official score files land under here.
BFCL_PROJECT_ROOT=./bfcl_runs

# Optional: pin the HF cache to fast/ephemeral disk on the GPU platform.
# HF_HOME=
